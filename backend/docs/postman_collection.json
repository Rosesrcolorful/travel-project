{
  "info": {
    "_postman_id": "a2cfe35f-4eec-4b23-a94d-ee2296ef37f3",
    "name": "TravelMate Final API Collection",
    "description": "Final Postman collection for the TravelMate full-stack project. The backend should be running on http://localhost:3000. Most requests use the standard response format: { success, data, error }. Socket.IO live-chat behavior is demonstrated in the website/demo video, while this collection tests the REST API routes.\n\nRoute note: auth, settings, and AI requests use /api/... because those routes are mounted with the /api prefix. Trips, friends, messages, users, and trip-shares use their direct route paths.\n\nSettings update note: the Update profile and theme request uses collection variables settingsUsername, settingsEmail, and settingsTheme. Edit those variables before running it so a user is not overwritten by hardcoded example values.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "53605521"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup new user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login/signup response is successful\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const user = json.data && (json.data.user || json.data);",
                  "if (user && user.id) {",
                  "  pm.collectionVariables.set(\"userId\", user.id);",
                  "}",
                  "if (user && user.email) {",
                  "  pm.collectionVariables.set(\"currentUserEmail\", user.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Tester\",\n  \"username\": \"postman_tester\",\n  \"email\": \"postman.tester@example.com\",\n  \"password\": \"Test1234!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
